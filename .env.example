# Root .env consumed by docker-compose.yml (livekit + token-server + caddy).
#
# Normally you don't hand-write this file — running `./init-livekit.sh`
# generates it for you (fresh LiveKit API key/secret, detects the server's
# public IP, writes LK_HOST/LIVEKIT_URL). See docs/README.md.

# Domain or IP of this server. A real domain gets a trusted Let's Encrypt
# certificate from Caddy automatically; a bare IP falls back to a
# self-signed certificate (browsers/webview will warn about it).
LK_HOST=your-domain-or-ip

# WebSocket URL clients use to reach the LiveKit SFU, via the Caddy reverse
# proxy (no port — 443 is implied). Must use the same host as LK_HOST.
LIVEKIT_URL=wss://your-domain-or-ip

# Shared secret between livekit and token-server — generate with
# `docker run --rm livekit/livekit-server generate-keys` (init-livekit.sh
# does this for you).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Port token-server listens on internally (also used by Caddy to reach it
# via loopback — see Caddyfile).
TOKEN_SERVER_PORT=3001

# CORS origins allowed to call the token server.
ALLOWED_ORIGIN=http://localhost:1420,tauri://localhost,http://tauri.localhost
