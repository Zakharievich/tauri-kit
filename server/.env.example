# LiveKit SFU connection — must match the values used by livekit (see root
# .env / init-livekit.sh) and agent/.env.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=ws://localhost:7880

# CORS: comma-separated list of allowed origins. Defaults already cover the
# Vite dev server plus both Tauri desktop-client origins (macOS/Linux use
# tauri://localhost, Windows uses http://tauri.localhost) — override only
# for a non-default setup.
ALLOWED_ORIGIN=http://localhost:1420,tauri://localhost,http://tauri.localhost

# Port the token server listens on.
PORT=3001

# Access token lifetime, in seconds (default: 1 hour).
TOKEN_TTL_SECONDS=3600
