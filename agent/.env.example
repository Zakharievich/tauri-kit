# LiveKit SFU connection (see server/.env.example for matching values)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Speech-to-text (faster-whisper-server, OpenAI-compatible API)
# If false, the agent logs a warning and exits without joining the room.
ENABLE_STT=true
FASTER_WHISPER_URL=http://localhost:8000/v1
FASTER_WHISPER_MODEL=tiny

# Optional summary (Ollama). If Ollama is unreachable the agent logs a
# warning and continues without a summary (graceful degradation).
ENABLE_SUMMARY=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
